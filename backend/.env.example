# ═══════════════════════════════════════════════════════
#  AgroVision AI — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=5000
API_VERSION=v1
APP_NAME=AgroVision AI

# ── MongoDB ─────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/agrovision
# Atlas (production):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/agrovision?retryWrites=true&w=majority

MONGO_DB_NAME=agrovision

# ── JWT Auth ────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d

# ── Cookie ──────────────────────────────────────────────
COOKIE_SECRET=yet_another_long_random_string

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX=100             # max requests per window

# ── File Upload ─────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=debug               # error | warn | info | http | debug
LOG_DIR=logs

# ── External APIs ───────────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Agro Monitoring API (satellite NDVI)
AGROMONITORING_API_KEY=your_agromonitoring_key
AGROMONITORING_BASE_URL=https://app.agromonitoring.com/agro/1.0

# ── Python ML Service (disease detection) ───────────────
# Separate FastAPI/Flask service running the CNN model
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT_MS=15000

# ── Email (optional — for alerts) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@agrovision.ai
